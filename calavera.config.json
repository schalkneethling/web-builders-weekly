{
  "$schema": "https://calavera.schalkneethling.com/calavera.config.schema.json",
  "version": 1,
  "profile": "modern",
  "packageManager": "bun",
  "integrations": ["editorconfig", "stylelint", "stylelint-standard", "stylelint-baseline"],
  "scripts": {
    "lint": true,
    "lint:fix": true,
    "format": true,
    "format:check": true,
    "typecheck": true,
    "quality": true
  },
  "ai": [
    {
      "type": "skill",
      "src": "skills/semantic-html"
    },
    {
      "type": "skill",
      "src": "skills/css-coder"
    },
    {
      "type": "skill",
      "src": "skills/frontend-security"
    },
    {
      "type": "skill",
      "src": "skills/frontend-testing"
    },
    {
      "type": "skill",
      "src": "skills/more-secure-dependabot-config"
    },
    {
      "type": "skill",
      "src": "skills/npm-publishing-best-practices"
    },
    {
      "type": "skill",
      "src": "skills/npm-trusted-publishing-github-workflow"
    }
  ]
}
